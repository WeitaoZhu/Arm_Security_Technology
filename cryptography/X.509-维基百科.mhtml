.mw-message-box { color: rgb(0, 0, 0); box-sizing: border-box; margin-botto=
m: 16px; border: 1px solid rgb(162, 169, 177); padding: 12px 24px; overflow=
-wrap: break-word; overflow: hidden; background-color: rgb(234, 236, 240); =
}

.mw-message-box :only-child { margin: 0px; }

.mw-message-box h2 { color: inherit; display: block; border: 0px; font-size=
: 1em; font-weight: bold; }

.mw-message-box .mw-logevent-loglines li { font-size: 90%; }

.mw-message-box-error { background-color: rgb(254, 231, 230); border-color:=
 rgb(221, 51, 51); }

.mw-message-box-warning { background-color: rgb(254, 246, 231); border-colo=
r: rgb(255, 204, 51); }

.mw-message-box-success { background-color: rgb(213, 253, 244); border-colo=
r: rgb(20, 134, 109); }

#ca-varlang-0, #ca-varlang-1, #ca-varlang-2, #mw-mf-language-variant-select=
ion > li:nth-child(-n+3) { display: none !important; }

.geo-nondefault, .geo-multi-punct, .sysop-show, .accountcreator-show, .auto=
confirmed-show, .hide-when-compact, .noprint.portal { display: none; }

@media (min-width: 768px) {
  #content .vertical-navbox, #content .navbox { display: inherit; }
}

@media screen, handheld {
  .citation .printonly { display: none; }
}

.citation { overflow-wrap: break-word; }

.navbar { display: inline; font-size: 88%; font-weight: normal; }

.navbar ul { display: inline; white-space: nowrap; }

.navbar li { word-spacing: -0.125em; }

.navbar.mini li span { font-variant: small-caps; }

.infobox .navbar { font-size: 100%; }

.navbox .navbar { display: block; font-size: 100%; }

.navbox-title .navbar { float: left; text-align: left; margin-right: 0.5em;=
 width: 6em; }

.hlist dl, .hlist ol, .hlist ul { margin: 0px; padding: 0px; }

.hlist dd, .hlist dt, .hlist li { margin: 0px; display: inline; }

.hlist dl dl, .hlist dl ol, .hlist dl ul, .hlist ol dl, .hlist ol ol, .hlis=
t ol ul, .hlist ul dl, .hlist ul ol, .hlist ul ul { display: inline; }

